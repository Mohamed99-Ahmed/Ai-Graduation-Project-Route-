## 9. Prop Spreading (Use Carefully)

```typescript
// ✅ GOOD - Extend native HTML when needed
interface InputProps extends Omit<React.InputHTMLAttributes<HTMLInputElement>, 'size'> {
  label: string;
  error?: string;
  size?: 'sm' | 'md' | 'lg';
}

export const Input = React.forwardRef<HTMLInputElement, InputProps>(
  ({ label, error, className, ...inputProps }, ref) => (
    <div>
      <label>{label}</label>
      <input ref={ref} className={cn('input', className)} {...inputProps} />
      {error && <span className="text-destructive">{error}</span>}
    </div>
  )
);

// ❌ BAD - Unclear props
export const Button = (props: any) => <button {...props} />;
```

